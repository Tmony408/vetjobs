# Copy to .env and fill in.

# --- Database ---
# Local (with the included docker-compose):
DATABASE_URL=postgres://vetjobs:vetjobs@localhost:5432/vetjobs
# Or a free hosted Postgres (Neon / Supabase / Railway): paste their connection URL here.

PORT=4000

# Allow the Next.js frontend to call this API.
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
# Used to sign login tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- AI cover letters (optional) ---
# Works with any OpenAI-compatible provider. Leave blank to use the built-in
# generator. FREE option: Groq (sign up at console.groq.com, no card).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# (For OpenAI instead: LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini)
