# Copy to .env and fill in.

# --- Database ---
# Local (with the included docker-compose):
DATABASE_URL=postgres://vetjobs:vetjobs@localhost:5432/vetjobs
# Or a free hosted Postgres (Neon / Supabase / Railway): paste their connection URL here.

PORT=4000

# Allow the Next.js frontend to call this API.
CORS_ORIGIN=http://localhost:3000

# --- Auth (Supabase) ---
# The backend verifies Supabase access tokens. From Supabase Settings -> API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- AI cover letters (optional) ---
# Works with any OpenAI-compatible provider. Leave blank to use the built-in
# generator. FREE option: Groq (sign up at console.groq.com, no card).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# --- AWS S3 (media / CV file storage) ---
AWS_REGION=us-east-1
S3_BUCKET=vetjobs-media
# On EKS, prefer IAM Roles for Service Accounts (IRSA) over keys. Locally / on
# non-AWS hosts, set these and the SDK picks them up automatically:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# To use an S3-compatible provider instead of AWS (Cloudflare R2, Supabase, MinIO),
# also set these (see S3-MEDIA.md):
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=https://files.yourdomain.com
# (For OpenAI instead: LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini)
