# Copy to .env.local. Where the NestJS API lives.
# Local default (if you run vetjobs-api on port 4000) — you can leave this as-is.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ---------------------------------------------------------------------------
# Optional job-source API keys. The job feed lives in the Next /api/jobs route,
# so these go on the WEB service (not the backend). All free to obtain.
# Leave blank and those sources are simply skipped.
# ---------------------------------------------------------------------------

# JSearch (OpenWeb Ninja) — Google for Jobs, covers NIGERIA. Key from openwebninja.com (starts ak_).
JSEARCH_KEY=
JSEARCH_QUERY=jobs in Nigeria

# Adzuna — does NOT cover Nigeria (defaults to South Africa). Free key: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=za

# Jooble — covers NIGERIA. Free key: https://jooble.org/api/about
JOOBLE_KEY=

# Reed (UK) — free key: https://www.reed.co.uk/developers
REED_KEY=

# Findwork (remote/global) — free key: https://findwork.dev/developers
FINDWORK_KEY=
